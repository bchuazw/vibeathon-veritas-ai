# Environment variables for Veritas AI backend
# Copy this file to .env and fill in your actual API keys

# API Keys (required)
OPENAI_API_KEY=your_openai_api_key_here
NEWSAPI_KEY=your_newsapi_key_here

# Virlo API (optional - enables viral content optimization)
# Get your API key at https://virlo.ai/developers (500 free credits)
VIRLO_API_KEY=your_virlo_api_key_here
VIRLO_ENABLED=true

# Application settings (optional)
DEBUG=false
APP_NAME=Veritas AI
APP_VERSION=1.0.0

# NewsAPI settings (optional)
NEWSAPI_BASE_URL=https://newsapi.org/v2
NEWSAPI_PAGE_SIZE=20

# OpenAI settings (optional)
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKOKENS=2000
OPENAI_TEMPERATURE=0.7

# Pipeline settings (optional)
MAX_RETRIES=3
RETRY_DELAY=1.0
